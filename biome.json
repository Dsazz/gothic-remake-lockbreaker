{
	"$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"includes": ["**", "!!**/dist", "!!**/.cursor"]
	},
	"formatter": {
		"enabled": false
	},
	"assist": {
		"enabled": false
	},
	"css": {
		"linter": {
			"enabled": false
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"style": {
				"useTemplate": "off"
			},
			"complexity": {
				"useArrowFunction": "off"
			}
		}
	},
	"overrides": [
		{
			"includes": ["src/**"],
			"javascript": {
				"globals": [
					"window",
					"document",
					"localStorage",
					"sessionStorage",
					"location",
					"navigator",
					"setTimeout",
					"clearTimeout",
					"setInterval",
					"clearInterval",
					"queueMicrotask",
					"requestIdleCallback",
					"requestAnimationFrame",
					"fetch",
					"confirm",
					"URL",
					"URLSearchParams",
					"Event",
					"CustomEvent",
					"HTMLElement",
					"Element",
					"Node",
					"MutationObserver",
					"ResizeObserver",
					"matchMedia",
					"performance",
					"crypto",
					"structuredClone",
					"AbortController"
				]
			}
		},
		{
			"includes": ["tests/**", "scripts/**", "vite.config.js"],
			"javascript": {
				"globals": ["process"]
			}
		}
	]
}
